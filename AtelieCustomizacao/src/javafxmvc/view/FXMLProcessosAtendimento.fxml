<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLProcessosAtendimentoController">
   <children>
      <Label layoutX="14.0" layoutY="10.0" style="-fx-font-size: 14; -fx-font-weight: bold;" text="Ordens de Serviço - Atendimento" />
      <TableView fx:id="tableViewOS" layoutX="14.0" layoutY="35.0" prefHeight="280.0" prefWidth="620.0">
        <columns>
          <TableColumn fx:id="tableColumnOSId" prefWidth="75.0" text="OS ID" />
          <TableColumn fx:id="tableColumnOSCliente" prefWidth="300.0" text="Cliente" />
          <TableColumn fx:id="tableColumnOSStatus" prefWidth="245.0" text="Status" />
        </columns>
      </TableView>
      <Button fx:id="buttonInserir" layoutX="14.0" layoutY="330.0" mnemonicParsing="false" onAction="#handleButtonInserir" prefWidth="100.0" text="Nova OS" />
      <Button fx:id="buttonAlterar" layoutX="124.0" layoutY="330.0" mnemonicParsing="false" onAction="#handleButtonAlterar" prefWidth="100.0" text="Alterar" />
      <Button fx:id="buttonRemover" layoutX="234.0" layoutY="330.0" mnemonicParsing="false" onAction="#handleButtonRemover" prefWidth="100.0" text="Remover" />
   </children>
</AnchorPane>
