<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="340.0" prefWidth="480.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLProcessosTerceirizacaoDialogController">
   <children>
      <GridPane layoutX="20.0" layoutY="20.0" prefWidth="440.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="140.0" prefWidth="140.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="280.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
          <Label text="Ordem de Serviço:" />
          <Label text="Fábrica Parceira:" GridPane.rowIndex="1" />
          <Label text="Tipo de Serviço:" GridPane.rowIndex="2" />
          <Label text="Quantidade:" GridPane.rowIndex="3" />
          <Label text="Data Envio:" GridPane.rowIndex="4" />
          <ComboBox fx:id="comboBoxOS" prefWidth="275.0" GridPane.columnIndex="1" />
          <ComboBox fx:id="comboBoxFabrica" prefWidth="275.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          <ComboBox fx:id="comboBoxTipoServico" prefWidth="275.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
          <TextField fx:id="textFieldQuantidade" GridPane.columnIndex="1" GridPane.rowIndex="3" />
          <DatePicker fx:id="datePickerEnvio" prefWidth="275.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </children>
      </GridPane>
      <Button fx:id="buttonConfirmar" layoutX="280.0" layoutY="295.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" text="Confirmar" />
      <Button fx:id="buttonCancelar" layoutX="375.0" layoutY="295.0" mnemonicParsing="false" onAction="#handleButtonCancelar" text="Cancelar" />
   </children>
</AnchorPane>
