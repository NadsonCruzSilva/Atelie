<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="430.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLProcessosRetornoController">
   <children>
      <Label layoutX="14.0" layoutY="10.0" style="-fx-font-size: 14; -fx-font-weight: bold;" text="Retorno e Pagamento de Ordens de Serviço" />
      <TableView fx:id="tableViewOS" layoutX="14.0" layoutY="35.0" prefHeight="280.0" prefWidth="620.0">
        <columns>
          <TableColumn fx:id="tableColumnOSId" prefWidth="75.0" text="OS ID" />
          <TableColumn fx:id="tableColumnOSCliente" prefWidth="300.0" text="Cliente" />
          <TableColumn fx:id="tableColumnOSStatus" prefWidth="245.0" text="Status" />
        </columns>
      </TableView>
      <Label layoutX="14.0" layoutY="332.0" text="Valor Final (R$):" />
      <TextField fx:id="textFieldValorFinal" layoutX="130.0" layoutY="328.0" prefWidth="150.0" promptText="Opcional" />
      <Button fx:id="buttonFinalizar" layoutX="14.0" layoutY="368.0" mnemonicParsing="false" onAction="#handleButtonFinalizar" prefWidth="280.0" text="Registrar Retorno e Finalizar Pagamento" />
   </children>
</AnchorPane>
