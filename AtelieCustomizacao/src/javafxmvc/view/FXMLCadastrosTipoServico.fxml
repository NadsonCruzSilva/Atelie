<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLCadastrosTipoServicoController">
   <children>
      <TableView fx:id="tableViewTipoServico" layoutX="14.0" layoutY="14.0" prefHeight="260.0" prefWidth="390.0">
        <columns>
          <TableColumn fx:id="tableColumnTipoServicoId" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="tableColumnTipoServicoName" prefWidth="315.0" text="Descrição" />
        </columns>
      </TableView>
      <AnchorPane layoutX="420.0" layoutY="14.0" prefHeight="260.0" prefWidth="210.0" style="-fx-border-color: lightgray; -fx-padding: 10;">
        <children>
          <Label layoutX="0.0" layoutY="0.0" style="-fx-font-weight: bold;" text="Detalhes" />
          <Label layoutX="0.0" layoutY="25.0" text="Descrição:" />
          <Label fx:id="labelDescricao" layoutX="70.0" layoutY="25.0" prefWidth="140.0" />
          <Label layoutX="0.0" layoutY="50.0" text="Valor:" />
          <Label fx:id="labelValor" layoutX="50.0" layoutY="50.0" prefWidth="150.0" />
          <Label layoutX="0.0" layoutY="75.0" text="Prazo:" />
          <Label fx:id="labelPrazo" layoutX="50.0" layoutY="75.0" prefWidth="150.0" />
        </children>
      </AnchorPane>
      <Button fx:id="buttonInserir" layoutX="14.0" layoutY="295.0" mnemonicParsing="false" onAction="#handleButtonInserir" prefWidth="90.0" text="Inserir" />
      <Button fx:id="buttonAlterar" layoutX="114.0" layoutY="295.0" mnemonicParsing="false" onAction="#handleButtonAlterar" prefWidth="90.0" text="Alterar" />
      <Button fx:id="buttonRemover" layoutX="214.0" layoutY="295.0" mnemonicParsing="false" onAction="#handleButtonRemover" prefWidth="90.0" text="Remover" />
   </children>
</AnchorPane>
