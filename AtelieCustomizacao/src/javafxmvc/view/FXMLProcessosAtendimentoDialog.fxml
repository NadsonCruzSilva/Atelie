<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="300.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLProcessosAtendimentoDialogController">
   <children>
      <GridPane layoutX="20.0" layoutY="20.0" prefWidth="410.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="130.0" prefWidth="130.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="260.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
          <Label text="Cliente:" />
          <Label text="Tipo de Serviço:" GridPane.rowIndex="1" />
          <Label text="Data de Abertura:" GridPane.rowIndex="2" />
          <Label text="Valor Total (R$):" GridPane.rowIndex="3" />
          <ComboBox fx:id="comboBoxCliente" prefWidth="255.0" GridPane.columnIndex="1" />
          <ComboBox fx:id="comboBoxTipoServico" prefWidth="255.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          <DatePicker fx:id="datePickerAbertura" prefWidth="255.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
          <TextField fx:id="textFieldValor" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
      </GridPane>
      <Button fx:id="buttonConfirmar" layoutX="245.0" layoutY="260.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" text="Confirmar" />
      <Button fx:id="buttonCancelar" layoutX="340.0" layoutY="260.0" mnemonicParsing="false" onAction="#handleButtonCancelar" text="Cancelar" />
   </children>
</AnchorPane>
