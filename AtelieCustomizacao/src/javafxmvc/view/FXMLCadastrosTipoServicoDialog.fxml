<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="185.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLCadastrosTipoServicoDialogController">
   <children>
      <GridPane layoutX="20.0" layoutY="20.0" prefWidth="310.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="110.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="180.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
          <Label text="Descrição:" />
          <Label text="Valor (R$):" GridPane.rowIndex="1" />
          <Label text="Prazo (dias):" GridPane.rowIndex="2" />
          <TextField fx:id="textFieldDescricao" GridPane.columnIndex="1" />
          <TextField fx:id="textFieldValor" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          <TextField fx:id="textFieldPrazo" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </children>
      </GridPane>
      <Button fx:id="buttonConfirmar" layoutX="175.0" layoutY="147.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" text="Confirmar" />
      <Button fx:id="buttonCancelar" layoutX="260.0" layoutY="147.0" mnemonicParsing="false" onAction="#handleButtonCancelar" text="Cancelar" />
   </children>
</AnchorPane>
