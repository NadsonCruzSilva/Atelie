<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLGraficosVolumeController">
   <children>
      <BarChart fx:id="barChartVolume" layoutX="50.0" layoutY="20.0" prefHeight="350.0" prefWidth="500.0" title="Volume de Ordens por Fábrica">
        <xAxis>
          <CategoryAxis side="BOTTOM" fx:id="xAxis" />
        </xAxis>
        <yAxis>
          <NumberAxis side="LEFT" fx:id="yAxis" />
        </yAxis>
      </BarChart>
   </children>
</AnchorPane>
