<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="220.0" prefWidth="370.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLCadastrosFabricaParceiraDialogController">
   <children>
      <GridPane layoutX="20.0" layoutY="20.0" prefWidth="330.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="210.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
          <Label text="Nome:" />
          <Label text="CNPJ:" GridPane.rowIndex="1" />
          <Label text="Telefone:" GridPane.rowIndex="2" />
          <Label text="Especialidade:" GridPane.rowIndex="3" />
          <TextField fx:id="textFieldNome" GridPane.columnIndex="1" />
          <TextField fx:id="textFieldCnpj" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          <TextField fx:id="textFieldTelefone" GridPane.columnIndex="1" GridPane.rowIndex="2" />
          <TextField fx:id="textFieldEspecialidade" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
      </GridPane>
      <Button fx:id="buttonConfirmar" layoutX="195.0" layoutY="180.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" text="Confirmar" />
      <Button fx:id="buttonCancelar" layoutX="280.0" layoutY="180.0" mnemonicParsing="false" onAction="#handleButtonCancelar" text="Cancelar" />
   </children>
</AnchorPane>
