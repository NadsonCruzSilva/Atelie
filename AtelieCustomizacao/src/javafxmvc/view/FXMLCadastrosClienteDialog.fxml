<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="220.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxmvc.controller.FXMLCadastrosClienteDialogController">
   <children>
      <GridPane layoutX="20.0" layoutY="20.0" prefWidth="310.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="90.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
          <Label text="Nome:" />
          <Label text="CPF:" GridPane.rowIndex="1" />
          <Label text="Telefone:" GridPane.rowIndex="2" />
          <Label text="Endereço:" GridPane.rowIndex="3" />
          <TextField fx:id="textFieldNome" GridPane.columnIndex="1" />
          <TextField fx:id="textFieldCpf" GridPane.columnIndex="1" GridPane.rowIndex="1" />
          <TextField fx:id="textFieldTelefone" GridPane.columnIndex="1" GridPane.rowIndex="2" />
          <TextField fx:id="textFieldEndereco" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </children>
      </GridPane>
      <Button fx:id="buttonConfirmar" layoutX="175.0" layoutY="180.0" mnemonicParsing="false" onAction="#handleButtonConfirmar" text="Confirmar" />
      <Button fx:id="buttonCancelar" layoutX="260.0" layoutY="180.0" mnemonicParsing="false" onAction="#handleButtonCancelar" text="Cancelar" />
   </children>
</AnchorPane>
