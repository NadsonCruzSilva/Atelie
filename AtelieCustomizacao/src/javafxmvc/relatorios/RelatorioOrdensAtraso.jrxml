<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioOrdensAtraso"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!--
        Ordens em atraso: OS com status ENVIADA_FABRICA cuja data_retorno_prevista é anterior a HOJE.
        Inclui nome da fábrica e dias de atraso calculados.
    -->
    <parameter name="nome_fabrica" class="java.lang.String">
        <defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
    </parameter>
    <queryString>
        <![CDATA[
            SELECT
                os.id                                            AS os_id,
                c.nome                                           AS cliente,
                fp.nome                                          AS fabrica,
                e.data_encaminhamento,
                e.data_retorno_prevista,
                CURRENT_DATE - e.data_retorno_prevista           AS dias_atraso,
                ts.descricao                                     AS tipo_servico
            FROM encaminhamento e
            JOIN ordem_servico os  ON e.ordem_servico_id    = os.id
            JOIN cliente c         ON os.cliente_id         = c.id
            JOIN fabrica_parceira fp ON e.fabrica_parceira_id = fp.id
            JOIN tipo_servico ts   ON e.tipo_servico_id     = ts.id
            WHERE os.status = 'ENVIADA_FABRICA'
              AND e.data_retorno_prevista < CURRENT_DATE
              AND fp.nome ILIKE $P{nome_fabrica}
            ORDER BY dias_atraso DESC
        ]]>
    </queryString>

    <field name="os_id"                 class="java.lang.Integer"/>
    <field name="cliente"               class="java.lang.String"/>
    <field name="fabrica"               class="java.lang.String"/>
    <field name="data_encaminhamento"   class="java.sql.Date"/>
    <field name="data_retorno_prevista" class="java.sql.Date"/>
    <field name="dias_atraso"           class="java.lang.Integer"/>
    <field name="tipo_servico"          class="java.lang.String"/>

    <variable name="TOTAL_ATRASOS" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{os_id}]]></variableExpression>
    </variable>

    <background><band/></background>

    <!-- TÃTULO -->
    <title>
        <band height="80">
            <frame>
                <reportElement mode="Opaque" x="-20" y="-20" width="595" height="100" backcolor="#8B0000"/>
                <staticText>
                    <reportElement x="20" y="18" width="400" height="38" forecolor="#FFFFFF"/>
                    <textElement><font size="24" isBold="true"/></textElement>
                    <text><![CDATA[Ordens em Atraso por Fábrica]]></text>
                </staticText>
                <staticText>
                    <reportElement x="20" y="54" width="555" height="16" forecolor="#FFAAAA"/>
                    <textElement><font size="11"/></textElement>
                    <text><![CDATA[OS com status ENVIADA_FABRICA cuja data de retorno prevista já foi ultrapassada]]></text>
                </staticText>
            </frame>
        </band>
    </title>

    <pageHeader><band height="10"/></pageHeader>

    <!-- CABEÇALHO DAS COLUNAS -->
    <columnHeader>
        <band height="24">
            <staticText>
                <reportElement mode="Opaque" x="0"   y="0" width="45"  height="22" forecolor="#8B0000" backcolor="#FFD7D7"/>
                <textElement textAlignment="Center"><font size="11" isBold="true"/></textElement>
                <text><![CDATA[OS #]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="45"  y="0" width="140" height="22" forecolor="#8B0000" backcolor="#FFD7D7"/>
                <textElement textAlignment="Left"><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Cliente]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="185" y="0" width="140" height="22" forecolor="#8B0000" backcolor="#FFD7D7"/>
                <textElement textAlignment="Left"><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Fábrica]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="325" y="0" width="110" height="22" forecolor="#8B0000" backcolor="#FFD7D7"/>
                <textElement textAlignment="Center"><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Prazo Previsto]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="435" y="0" width="120" height="22" forecolor="#8B0000" backcolor="#FFD7D7"/>
                <textElement textAlignment="Center"><font size="11" isBold="true"/></textElement>
                <text><![CDATA[Dias em Atraso]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="23" width="555" height="1" forecolor="#8B0000"/>
            </line>
        </band>
    </columnHeader>

    <!-- DETALHE -->
    <detail>
        <band height="22">
            <textField>
                <reportElement x="0"   y="1" width="45"  height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{os_id}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="45"  y="1" width="140" height="20"/>
                <textElement textAlignment="Left"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{cliente}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="185" y="1" width="140" height="20"/>
                <textElement textAlignment="Left"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{fabrica}]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="325" y="1" width="110" height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{data_retorno_prevista}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="435" y="1" width="120" height="20" forecolor="#CC0000"/>
                <textElement textAlignment="Center"><font size="12" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{dias_atraso} + " dias"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement positionType="FixRelativeToBottom" x="0" y="21" width="555" height="1" forecolor="#CCCCCC"/>
            </line>
        </band>
    </detail>

    <columnFooter><band/></columnFooter>

    <!-- RODAPÉ DE PÁGINA -->
    <pageFooter>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement mode="Opaque" x="0" y="4" width="200" height="13" backcolor="#FFE8E8"/>
                <textElement textAlignment="Left"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement mode="Opaque" x="445" y="4" width="70" height="13" backcolor="#FFE8E8"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER} + " de"]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement mode="Opaque" x="515" y="4" width="40" height="13" backcolor="#FFE8E8"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- SUMÁRIO -->
    <summary>
        <band height="40">
            <line>
                <reportElement x="0" y="4" width="555" height="2" forecolor="#8B0000"/>
            </line>
            <staticText>
                <reportElement x="0" y="10" width="435" height="22"/>
                <textElement textAlignment="Right"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[TOTAL DE ORDENS EM ATRASO:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="10" width="120" height="22" forecolor="#8B0000"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_ATRASOS}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
