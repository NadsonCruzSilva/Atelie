<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioRankingFabricas"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!--
        Ranking de Fábricas Parceiras:
        Mostra total de encaminhamentos, ordens entregues e valor total movimentado por fábrica.
        Ordenado pelo valor total movimentado (descendente).
    -->
    <parameter name="especialidade" class="java.lang.String">
        <defaultValueExpression><![CDATA["%"]]></defaultValueExpression>
    </parameter>
    <queryString>
        <![CDATA[
            SELECT
                fp.nome                               AS fabrica,
                fp.especialidade,
                COUNT(e.id)                           AS total_encaminhamentos,
                COUNT(CASE WHEN os.status = 'FINALIZADA' THEN 1 END) AS ordens_finalizadas,
                COUNT(CASE WHEN os.status = 'ENVIADA_FABRICA' THEN 1 END) AS ordens_ativas,
                COALESCE(SUM(e.valor_servico), 0)     AS valor_total_movimentado
            FROM fabrica_parceira fp
            LEFT JOIN encaminhamento e ON fp.id = e.fabrica_parceira_id
            LEFT JOIN ordem_servico os ON e.ordem_servico_id = os.id
            WHERE COALESCE(fp.especialidade, '') ILIKE $P{especialidade}
            GROUP BY fp.id, fp.nome, fp.especialidade
            ORDER BY valor_total_movimentado DESC NULLS LAST
        ]]>
    </queryString>

    <field name="fabrica"                  class="java.lang.String"/>
    <field name="especialidade"            class="java.lang.String"/>
    <field name="total_encaminhamentos"    class="java.lang.Long"/>
    <field name="ordens_finalizadas"       class="java.lang.Long"/>
    <field name="ordens_ativas"            class="java.lang.Long"/>
    <field name="valor_total_movimentado"  class="java.lang.Double"/>

    <variable name="POSICAO" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{fabrica}]]></variableExpression>
    </variable>
    <variable name="VALOR_GERAL" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{valor_total_movimentado}]]></variableExpression>
    </variable>

    <background><band/></background>

    <!-- TÃTULO -->
    <title>
        <band height="80">
            <frame>
                <reportElement mode="Opaque" x="-20" y="-20" width="595" height="100" backcolor="#1A5276"/>
                <staticText>
                    <reportElement x="20" y="18" width="400" height="38" forecolor="#FFFFFF"/>
                    <textElement><font size="23" isBold="true"/></textElement>
                    <text><![CDATA[Ranking de Fábricas Parceiras]]></text>
                </staticText>
                <staticText>
                    <reportElement x="20" y="55" width="555" height="16" forecolor="#AED6F1"/>
                    <textElement><font size="11"/></textElement>
                    <text><![CDATA[Desempenho e volume financeiro por fábrica parceira — Ateliê de Customização]]></text>
                </staticText>
            </frame>
        </band>
    </title>

    <pageHeader><band height="10"/></pageHeader>

    <!-- CABEÃ‡ALHO DAS COLUNAS -->
    <columnHeader>
        <band height="24">
            <staticText>
                <reportElement mode="Opaque" x="0"   y="0" width="30"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="30"  y="0" width="145" height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Left"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Fábrica]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="175" y="0" width="95"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Left"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Especialidade]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="270" y="0" width="70"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Envios]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="340" y="0" width="70"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Finalizadas]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="410" y="0" width="55"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Ativas]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="465" y="0" width="90"  height="22" forecolor="#1A5276" backcolor="#D6EAF8"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Valor Total]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="23" width="555" height="1" forecolor="#1A5276"/>
            </line>
        </band>
    </columnHeader>

    <!-- DETALHE -->
    <detail>
        <band height="22">
            <!-- PosiÃ§Ã£o no ranking -->
            <textField>
                <reportElement x="0"   y="1" width="30"  height="20"/>
                <textElement textAlignment="Center"><font size="11" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{POSICAO} + "º"]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="30"  y="1" width="145" height="20"/>
                <textElement textAlignment="Left"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{fabrica}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="175" y="1" width="95"  height="20"/>
                <textElement textAlignment="Left"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{especialidade} != null ? $F{especialidade} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="270" y="1" width="70"  height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{total_encaminhamentos}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="340" y="1" width="70"  height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{ordens_finalizadas}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="410" y="1" width="55"  height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{ordens_ativas}]]></textFieldExpression>
            </textField>
            <textField pattern="R$ #,##0.00">
                <reportElement x="465" y="1" width="90"  height="20"/>
                <textElement textAlignment="Right"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{valor_total_movimentado}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement positionType="FixRelativeToBottom" x="0" y="21" width="555" height="1" forecolor="#CCCCCC"/>
            </line>
        </band>
    </detail>

    <columnFooter><band/></columnFooter>

    <!-- RODAPÃ‰ DE PÃ GINA -->
    <pageFooter>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement mode="Opaque" x="0" y="4" width="200" height="13" backcolor="#D6EAF8"/>
                <textElement textAlignment="Left"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement mode="Opaque" x="445" y="4" width="70" height="13" backcolor="#D6EAF8"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER} + " de"]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement mode="Opaque" x="515" y="4" width="40" height="13" backcolor="#D6EAF8"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- SUMÃ RIO -->
    <summary>
        <band height="40">
            <line>
                <reportElement x="0" y="4" width="555" height="2" forecolor="#1A5276"/>
            </line>
            <staticText>
                <reportElement x="0" y="10" width="465" height="22"/>
                <textElement textAlignment="Right"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[TOTAL GERAL MOVIMENTADO:]]></text>
            </staticText>
            <textField pattern="R$ #,##0.00">
                <reportElement x="465" y="10" width="90" height="22" forecolor="#1A5276"/>
                <textElement textAlignment="Right"><font size="13" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{VALOR_GERAL}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>

